      {
        "of": [
          {
            "marks": {
              "annotations": [
                {
                  "i18nTitleKey": "inputs.portable-text.annotation.link",
                  "options": {
                    "modal": {
                      "type": "popover"
                    }
                  },
                  "fields": [
                    {
                      "validation": [
                        {
                          "rules": [
                            {
                              "flag": "uri",
                              "constraint": {
                                "options": {
                                  "scheme": [
                                    "/^http$/",
                                    "/^https$/",
                                    "/^tel$/",
                                    "/^mailto$/"
                                  ],
                                  "allowRelative": true,
                                  "relativeOnly": false,
                                  "allowCredentials": false
                                }
                              }
                            }
                          ],
                          "level": "error"
                        }
                      ],
                      "description": "A valid web, email, phone, or relative link.",
                      "name": "href",
                      "type": "url",
                      "title": "Link"
                    }
                  ],
                  "name": "link",
                  "type": "object"
                }
              ],
              "decorators": [
