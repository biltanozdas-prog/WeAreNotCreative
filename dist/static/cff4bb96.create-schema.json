  {
    "fields": [
      {
        "options": {
          "accept": "video/*"
        },
        "description": "Full-screen video that plays on the homepage background. Upload an MP4 file. Recommended: short loop, no audio needed.",
        "name": "heroVideo",
        "type": "file",
        "title": "Homepage — Hero Video"
      },
      {
        "description": "The large heading in the manifesto section. Shown in all-caps below the hero video. Example: \"Design as a cultural practice.\"",
        "name": "headline",
        "type": "string",
        "title": "Homepage — Headline"
      },
      {
        "rows": 4,
        "description": "The paragraph of body text below the headline. Describes the studio's mission. Shown indented below the heading.",
        "name": "manifestoText",
        "type": "text",
        "title": "Homepage — Manifesto Text"
      },
      {
        "description": "Projects shown in the scrolling showcase on the homepage. Leave empty to show the 4 most recent published projects automatically.",
        "of": [
          {
            "to": [
              {
                "type": "project"
              }
            ],
            "type": "reference",
            "title": "Reference to project"
          }
        ],
        "name": "selectedProjects",
        "type": "array",
        "title": "Homepage — Featured Projects"
      },
      {
        "description": "Small uppercase label above the CTA heading at the bottom of the page. Default appearance: \"Next Step\".",
        "name": "ctaLabel",
        "type": "string",
        "title": "CTA Section — Eyebrow Label"
      },
      {
        "description": "Large heading in the footer CTA block. Default appearance: \"LET'S TALK.\"",
        "name": "ctaHeadline",
        "type": "string",
        "title": "CTA Section — Headline"
      },
      {
        "description": "Link text in the CTA block. Default appearance: \"Start a Conversation\".",
        "name": "ctaButtonText",
        "type": "string",
        "title": "CTA Section — Button Text"
      },
      {
        "rows": 3,
        "description": "Short teaser text for the About section on the homepage. Leave blank if not used.",
        "name": "aboutText",
        "type": "text",
        "title": "Homepage — About Preview (optional)"
      }
    ],
    "name": "homepage",
    "type": "document"
  },
  {
    "fields": [
      {
        "description": "Small uppercase label shown above the headline. Default appearance: \"Who We Are\".",
        "name": "eyebrowLabel",
        "type": "string",
        "title": "Page Eyebrow Label"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error",
            "message": "Headline is required."
          }
        ],
        "description": "The large heading shown at the top of the About page. Usually \"ABOUT\".",
        "name": "headline",
        "type": "string",
        "title": "Page Headline"
      },
      {
        "description": "A short paragraph introducing the studio. Shown below the headline.",
        "name": "intro",
        "type": "text",
        "title": "Studio Introduction"
      },
      {
        "description": "Three short statements that define the studio's positioning. Shown in columns below the intro text.",
        "of": [
          {
            "fields": [
              {
                "description": "e.g. \"We Work With\", \"Philosophy\"",
                "name": "title",
                "type": "string",
                "title": "Column Heading"
              },
              {
                "description": "Short description for this positioning column.",
                "name": "text",
                "type": "text",
                "title": "Column Text"
              }
            ],
            "type": "object"
          }
        ],
        "name": "positioning",
        "type": "array",
        "title": "Positioning Columns"
      },
      {
        "description": "Photos displayed in the image slider on the right side of the About page. Upload multiple images — they will cycle automatically.",
        "of": [
          {
            "fields": [
              {
                "options": {
                  "hotspot": true
                },
                "name": "image",
                "type": "image",
                "title": "Photo"
              },
              {
                "description": "Describe the photo briefly (for accessibility). Optional.",
                "name": "alt",
                "type": "string",
                "title": "Image Description"
              }
            ],
            "type": "object"
          }
        ],
        "name": "galleryImages",
        "type": "array",
        "title": "Studio Gallery"
      },
      {
        "initialValue": true,
        "description": "Turn on to display the team member list on the About page.",
        "name": "showTeamSection",
        "type": "boolean"
      },
      {
        "description": "Small label above the CTA heading at the bottom of the page. Default appearance: \"Collaborate\".",
        "name": "ctaLabel",
        "type": "string",
        "title": "CTA Section — Eyebrow Label"
      },
      {
        "description": "Large CTA heading. Default appearance: \"WORK WITH US.\"",
        "name": "ctaHeadline",
        "type": "string",
        "title": "CTA Section — Headline"
      },
      {
        "description": "Link text in the CTA block. Default appearance: \"Start a Conversation\".",
        "name": "ctaButtonText",
        "type": "string",
        "title": "CTA Section — Button Text"
      }
    ],
    "name": "about",
    "type": "document",
    "title": "About Page"
  },
  {
    "fields": [
      {
        "description": "Small uppercase label shown above the headline. Default appearance: \"What We Do\".",
        "name": "eyebrowLabel",
        "type": "string",
        "title": "Page Eyebrow Label"
      },
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error",
            "message": "Headline is required."
          }
        ],
        "description": "The large heading shown at the top of the Services page. Usually \"SERVICES\".",
        "name": "headline",
        "type": "string",
        "title": "Page Headline"
      },
      {
        "description": "A short paragraph shown below the headline. Describes what the studio offers.",
        "name": "intro",
        "type": "text",
        "title": "Intro Text"
      },
      {
        "description": "Each service is displayed as an expandable row. Click [ + ] to add or reorder services.",
        "of": [
          {
            "fields": [
              {
                "description": "Display label, e.g. \"01\", \"02\". Used for visual ordering only.",
                "name": "number",
                "type": "string"
              },
              {
                "validation": [
                  {
                    "rules": [
                      {
                        "flag": "presence",
                        "constraint": "required"
                      }
                    ],
                    "level": "error",
                    "message": "Service name is required."
                  }
                ],
                "description": "The name shown in the expandable row header.",
                "name": "label",
                "type": "string",
                "title": "Service Name"
              },
              {
                "description": "One sentence describing this service. Shown when the row is expanded.",
                "name": "statement",
                "type": "text",
                "title": "Short Description"
              },
              {
                "description": "List of specific outputs for this service. Shown as tags when expanded.",
                "of": [
                  {
                    "type": "string"
                  }
                ],
                "name": "deliverables",
                "type": "array"
              },
              {
                "description": "Controls display order. Lower numbers appear first (1, 2, 3...).",
                "name": "order",
                "type": "number",
                "title": "Sort Order"
              }
            ],
            "type": "object"
          }
        ],
        "name": "disciplines",
        "type": "array",
        "title": "Services"
      },
      {
        "description": "Small label above the CTA heading at the bottom of the page. Default appearance: \"Ready?\".",
        "name": "ctaLabel",
        "type": "string",
        "title": "CTA Section — Eyebrow Label"
      },
      {
        "description": "Large CTA heading. Default appearance: \"LET'S BUILD SOMETHING.\"",
        "name": "ctaHeadline",
        "type": "string",
        "title": "CTA Section — Headline"
      },
      {
        "description": "Link text in the CTA block. Default appearance: \"Start a Project\".",
        "name": "ctaButtonText",
        "type": "string",
        "title": "CTA Section — Button Text"
      }
    ],
    "name": "services",
    "type": "document",
    "title": "Services Page"
  },
  {
    "fields": [
      {
        "description": "Small label shown above the email address. Default appearance: \"Start a Project\".",
        "name": "contactEyebrow",
        "type": "string",
        "title": "Contact Page — Eyebrow Label"
      },
      {
        "rows": 3,
        "description": "Short paragraph shown below the email address on the Contact page.",
        "name": "contactDescription",
        "type": "text",
        "title": "Contact Page — Description"
      },
      {
        "description": "The main contact email address. Shown as a large link on the Contact page.",
        "name": "email",
        "type": "string",
        "title": "Contact Email"
      },
      {
        "description": "Optional phone number displayed on the Contact page.",
        "name": "phone",
        "type": "string",
        "title": "Phone Number"
      },
      {
        "description": "Short location text shown at the bottom of the Contact page, e.g. \"Istanbul / Global\".",
        "name": "location",
        "type": "string",
        "title": "Studio Location"
      },
      {
        "description": "Full URL to the Instagram profile, e.g. \"https://instagram.com/wearenotcreative\".",
        "name": "instagramUrl",
        "type": "string",
        "title": "Instagram Link"
      },
      {
        "description": "Three columns shown on the Contact page explaining different types of inquiries.",
        "of": [
          {
            "fields": [
              {
                "description": "e.g. \"New Projects\", \"Collaborations\", \"General\".",
                "name": "label",
                "type": "string",
                "title": "Category Name"
              },
              {
                "description": "Short text explaining what kind of inquiry this covers.",
                "name": "description",
                "type": "text",
                "title": "Category Description"
              }
            ],
            "type": "object"
          }
        ],
        "name": "inquiryCategories",
        "type": "array"
      }
    ],
